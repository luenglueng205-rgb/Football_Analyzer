        "max_parlay": 3,
        "support_mxn": true,
        "support_single": true
      },
      "总进球": {
        "name": "总进球数",
        "code": "ZJQ",
        "options": ["0", "1", "2", "3", "4", "5", "6", "7+"],
        "option_names": {"0": "0球", "1": "1球", "2": "2球", "3": "3球", "4": "4球", "5": "5球", "6": "6球", "7+": "7+球"},
