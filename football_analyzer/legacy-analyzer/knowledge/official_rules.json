      "半全场": {
        "name": "半全场胜平负",
        "code": "BQC",
        "options": [
          "3-3", "3-1", "3-0",
          "1-3", "1-1", "1-0",
          "0-3", "0-1", "0-0"
        ],
        "option_names": {
          "3-3": "胜胜", "3-1": "胜平", "3-0": "胜负",
          "1-3": "平胜", "1-1": "平平", "1-0": "平负",
          "0-3": "负胜", "0-1": "负平", "0-0": "负负"
