        "max_parlay": 3,
        "support_mxn": true,
        "support_single": true
      }
    },
    "投注方式": {
      "单场投注": {
        "description": "只选择1场比赛进行投注",
        "min_bet": 2,
        "max_bet": 10000,
        "max_prize": 100000
      },
      "过关投注": {
        "description": "选择2-8场比赛串联投注",
        "min_parlay": 2,
        "max_parlay": 8,
        "multiplier_range": [1, 99]
      },
      "混合过关": {
        "description": "同一票中混合选择不同玩法进行串关",
        "allowed_combinations": [
          ["胜平负", "让球胜平负"],
          ["胜平负", "总进球"],
          ["胜平负", "比分"],
          ["胜平负", "半全场"],
          ["让球胜平负", "总进球"],
          ["让球胜平负", "比分"],
          ["让球胜平负", "半全场"],
          ["总进球", "比分"],
          ["总进球", "半全场"],
          ["比分", "半全场"],
          ["胜平负", "让球胜平负", "总进球", "比分", "半全场"]
        ]
      }
    },
    "奖金规则": {
      "prize_type": "固定奖金",
      "prize_description": "投注时锁定奖金，不受后续调整影响",
      "prize_calculation": "单注奖金 = 投注金额 × 各场次所选选项固定奖金乘积",
      "prize_limits": {
        "单场": 100000,
        "2-3关": 200000,
        "4-5关": 500000,
        "6关及以上": 1000000
      }
    }
  },
  
