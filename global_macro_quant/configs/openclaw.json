{
  "$schema": "https://openclaw.ai/schema.json",
  "name": "global-macro-quant-system",
  "version": "2026.04.11",
  "description": "原生多智能体全球宏观量化投资系统 (Native Multi-Agent Global Macro Quant System)",
  "homepage": "https://github.com/luenglueng205-rgb/Football-AnalystAgent",

  "agents": {
    "defaults": {
      "provider": "anthropic",
      "model": "claude-3-5-sonnet-20241022",
      "maxTokens": 8192,
      "temperature": 0.3,
      "subagents": {
        "maxConcurrent": 8,
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 5,
        "runTimeoutSeconds": 600,
        "thinking": "high",
        "cleanup": "delete"
      }
    },

    "list": [
      {
        "id": "orchestrator",
        "name": "首席基金经理 (Orchestrator)",
        "description": "整个宏观量化基金的灵魂人物，负责拆解全球经济意图，并将任务分发给不同资产类别的研究员与风控官",
        "default": true,
        "workspace": "agents/orchestrator/workspace",
        "model": "claude-3-5-sonnet-20241022",
        "systemPrompt": "你是顶级宏观对冲基金的首席基金经理。收到市场信号后，你必须调动你的下属(macro-analyst, quant-strategist)进行数据分析。策略出炉后，必须经过 risk-manager 进行风险平价优化和回测验证，若回测结果(如最大回撤)不达标，必须打回重做。",
        "subagents": {
          "allowAgents": ["macro-analyst", "quant-strategist", "risk-manager"]
        },
        "sandbox": {
          "mode": "off"
        }
      },
      {
        "id": "macro-analyst",
        "name": "宏观经济分析师 (Macro Analyst)",
        "description": "专职阅读全球央行政策、CPI数据及新闻情绪，具备动态去技能市场挂载抓取工具的能力",
        "workspace": "agents/macro-analyst/workspace",
        "model": "claude-3-5-haiku-20241022",
        "temperature": 0.2,
        "skills": ["dynamic-discovery"],
        "sandbox": {
          "mode": "agent"
        }
      },
      {
        "id": "quant-strategist",
        "name": "量化策略师 (Quant Strategist)",
        "description": "负责因子挖掘，根据宏观定性结论生成量化多空方向及初始配置权重",
        "workspace": "agents/quant-strategist/workspace",
        "model": "claude-3-5-sonnet-20241022",
        "temperature": 0.1,
        "skills": ["global-quant-tools"],
        "sandbox": {
          "mode": "agent"
        }
      },
      {
        "id": "risk-manager",
        "name": "首席风控官 (Risk Manager)",
        "description": "系统安全红线的守护者。负责计算资产协方差矩阵，强制执行风险平价 (Risk Parity)，并在沙箱中跑历史回测",
        "workspace": "agents/risk-manager/workspace",
        "model": "claude-3-5-sonnet-20241022",
        "temperature": 0.0,
        "skills": ["global-quant-tools"],
        "sandbox": {
          "mode": "agent"
        }
      }
    ],

    "bindings": [
      {
        "agentId": "orchestrator",
        "match": {
          "channel": "console",
          "accountId": "default"
        }
      }
    ]
  },

  "skills": {
    "entries": {
      "global-quant-tools": {
        "enabled": true,
        "workspace": "tools",
        "schema": "quant_tools_schema.json"
      },
      "dynamic-discovery": {
        "enabled": true,
        "workspace": "skills",
        "schema": "discovery_schema.json"
      }
    }
  }
}